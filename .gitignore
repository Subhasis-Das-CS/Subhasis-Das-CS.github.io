# --- This is a frontend-only project for GitHub Pages deployment ---
# Exclude the Python backend stub (kept locally only so the dev preview keeps running).
backend/
/app/backend/
*.pyc
__pycache__/
.venv/
venv/

# Node
node_modules/
build/
dist/

# Env (keep .env.production so EmailJS keys are baked into the build)
.env.local
.env.development.local
.env.test.local

# Logs / system
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE / Tooling
.vscode/
.idea/
.emergent/

# Memory / test reports (Emergent internals)
memory/
test_reports/
tests/

# Misc top-level files we don't need on Pages
README.md.bak
-e 
# Environment and credential files
.env
.env.*
*.env
credentials.json
*.pem
*.key
.credentials
